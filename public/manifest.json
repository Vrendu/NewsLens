{
  "manifest_version": 3,
  "name": "NewsLens Chrome Extension",
  "version": "1.0",
  "description": "Empower users to critically analyze news articles by presenting alternative perspectives.",
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  },
  "browser_action": {
    "default_icon": {
      "48": "icon.png",
      "128": "icon.png"
    },
    "default_popup": "popup.html",
    "default_title": "NewsLens Extension"
  },
  "permissions": [
    "activeTab",
    "storage",
    "webNavigation"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    "content.js"
  ],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}